From 205a2a3a4298e317b4b5e709a246ad96930ad49e Mon Sep 17 00:00:00 2001
From: Ruslan Isaev <legale.legale@gmail.com>
Date: Fri, 1 May 2026 22:04:43 +0300
Subject: [PATCH] uboot-mediatek: add l2sh support

Signed-off-by: Ruslan Isaev <legale.legale@gmail.com>
---
 .../src/board/mediatek/mt7981/mt7981_rfb.c    |   6 +
 common/console.c   |  38 +-
 .../mt7981_yuncore_ax835_nor_defconfig        |   1 +
 include/l2sh.h     |  78 ++
 .../uboot-mediatek/src/include/l2sh_proto.h   | 402 ++++++++++
 net/Kconfig        |  33 +
 net/Makefile       |   1 +
 net/l2sh.c         | 705 ++++++++++++++++++
 8 files changed, 1263 insertions(+), 1 deletion(-)
 create mode 100644 include/l2sh.h
 create mode 100644 include/l2sh_proto.h
 create mode 100644 net/l2sh.c

diff --git a/board/mediatek/mt7981/mt7981_rfb.c b/board/mediatek/mt7981/mt7981_rfb.c
index d0a59914f..36a2a6049 100644
--- a/board/mediatek/mt7981/mt7981_rfb.c
+++ b/board/mediatek/mt7981/mt7981_rfb.c
@@ -24,6 +24,7 @@
 int board_late_init(void)
 {
 	struct udevice *dev;
+	int recovery = 0;
 
 	gd->env_valid = ENV_VALID;
 	if (!button_get_by_label(CONFIG_RESET_BUTTON_LABEL, &dev)) {
@@ -37,9 +38,14 @@ int board_late_init(void)
 		if (button_get_state(dev) == BUTTON_ON) {
 			puts("button pushed, resetting environment\n");
 			gd->env_valid = ENV_INVALID;
+			recovery = 1;
 		}
 	}
 	env_relocate();
+	// force l2sh in recovery even if persisted env has l2sh=0
+	// принудительно включаем l2sh в recovery, даже если в env было l2sh=0
+	if (recovery && IS_ENABLED(CONFIG_L2SH))
+		env_set("l2sh", "1");
 	return 0;
 }
 
diff --git a/common/console.c b/common/console.c
index 48586fd21..70c1398dc 100644
--- a/common/console.c
+++ b/common/console.c
@@ -20,6 +20,7 @@
 #include <stdio_dev.h>
 #include <exports.h>
 #include <env_internal.h>
+#include <l2sh.h>
 #include <video_console.h>
 #include <watchdog.h>
 #include <asm/global_data.h>
@@ -526,6 +527,13 @@ int fgetc(int file)
 		 */
 		for (;;) {
 			schedule();
+			if (file == stdin) {
+				// pull network input into the cli before waiting on serial
+				// сначала подаем сетевой ввод в cli, потом ждем serial
+				l2sh_poll();
+				if (l2sh_tstc())
+					return l2sh_getc();
+			}
 			if (CONFIG_IS_ENABLED(CONSOLE_MUX)) {
 				/*
 				 * Upper layer may have already called tstc() so
@@ -553,8 +561,16 @@ int fgetc(int file)
 
 int ftstc(int file)
 {
-	if ((unsigned int)file < MAX_FILES)
+	if ((unsigned int)file < MAX_FILES) {
+		if (file == stdin) {
+			// poll here too so non-blocking stdin keeps the session alive
+			// опрашиваем и здесь, чтобы неблокирующий stdin не давал сессии протухнуть
+			l2sh_poll();
+			if (l2sh_tstc())
+				return 1;
+		}
 		return console_tstc(file);
+	}
 
 	return -1;
 }
@@ -614,6 +630,12 @@ int getchar(void)
 	if (ch != -1)
 		return ch;
 
+	// let l2sh preempt the regular console read path
+	// даем l2sh забрать ввод раньше обычного консольного пути
+	l2sh_poll();
+	if (l2sh_tstc())
+		return l2sh_getc();
+
 	if (gd->flags & GD_FLG_DEVINIT) {
 		/* Get from the standard input */
 		return fgetc(stdin);
@@ -634,6 +656,12 @@ int tstc(void)
 	if (console_record_tstc())
 		return 1;
 
+	// surface pending l2sh input on non-blocking console checks
+	// показываем ожидающий ввод l2sh и в неблокирующих проверках консоли
+	l2sh_poll();
+	if (l2sh_tstc())
+		return 1;
+
 	if (gd->flags & GD_FLG_DEVINIT) {
 		/* Test the standard input */
 		return ftstc(stdin);
@@ -747,6 +775,10 @@ void putc(const char c)
 		pre_console_putc(c);
 		serial_putc(c);
 	}
+
+	// mirror console output into the active l2sh session
+	// зеркалим вывод консоли в активную сессию l2sh
+	l2sh_putc(c);
 }
 
 void puts(const char *s)
@@ -787,6 +819,10 @@ void puts(const char *s)
 		pre_console_puts(s);
 		serial_puts(s);
 	}
+
+	// mirror console output into the active l2sh session
+	// зеркалим вывод консоли в активную сессию l2sh
+	l2sh_puts(s);
 }
 
 #ifdef CONFIG_CONSOLE_FLUSH_SUPPORT
diff --git a/configs/mt7981_yuncore_ax835_nor_defconfig b/configs/mt7981_yuncore_ax835_nor_defconfig
index 2d7d6d90a..ceb9a8bad 100644
--- a/configs/mt7981_yuncore_ax835_nor_defconfig
+++ b/configs/mt7981_yuncore_ax835_nor_defconfig
@@ -95,6 +95,7 @@ CONFIG_SPI_FLASH_XTX=y
 CONFIG_SPI_FLASH_MTD=y
 CONFIG_PHY_FIXED=y
 CONFIG_MEDIATEK_ETH=y
+CONFIG_L2SH=y
 CONFIG_PINCTRL=y
 CONFIG_PINCONF=y
 CONFIG_PINCTRL_MT7981=y
diff --git a/include/l2sh.h b/include/l2sh.h
new file mode 100644
index 000000000..4d854df3f
--- /dev/null
+++ b/include/l2sh.h
@@ -0,0 +1,78 @@
+#ifndef __L2SH_H
+#define __L2SH_H
+
+#ifdef __UBOOT__
+
+#include <asm/byteorder.h>
+#include <linux/types.h>
+
+typedef __be16 be16;
+typedef __be32 be32;
+typedef __be64 be64;
+
+#else
+
+#include <arpa/inet.h>
+#include <stdint.h>
+
+typedef uint8_t  u8;
+typedef uint16_t u16;
+typedef uint32_t u32;
+typedef uint64_t u64;
+typedef int8_t   s8;
+typedef int16_t  s16;
+typedef int32_t  s32;
+typedef int64_t  s64;
+
+typedef u16 be16;
+typedef u32 be32;
+typedef u64 be64;
+
+#define cpu_to_be16(x) htons(x)
+#define cpu_to_be32(x) htonl(x)
+#define be16_to_cpu(x) ntohs(x)
+#define be32_to_cpu(x) ntohl(x)
+
+#endif
+
+typedef u8 be8;
+
+#if defined(CONFIG_L2SH) && !defined(CONFIG_XPL_BUILD)
+s32 l2sh_init(void);
+void l2sh_poll(void);
+s32 l2sh_tstc(void);
+s32 l2sh_getc(void);
+void l2sh_putc(const char c);
+void l2sh_puts(const char *s);
+#else
+static inline s32 l2sh_init(void)
+{
+  return 0;
+}
+
+static inline void l2sh_poll(void)
+{
+}
+
+static inline s32 l2sh_tstc(void)
+{
+  return 0;
+}
+
+static inline s32 l2sh_getc(void)
+{
+  return -1;
+}
+
+static inline void l2sh_putc(const char c)
+{
+  (void)c;
+}
+
+static inline void l2sh_puts(const char *s)
+{
+  (void)s;
+}
+#endif
+
+#endif
diff --git a/include/l2sh_proto.h b/include/l2sh_proto.h
new file mode 100644
index 000000000..37bafb9ce
--- /dev/null
+++ b/include/l2sh_proto.h
@@ -0,0 +1,402 @@
+#ifndef __L2SH_PROTO_H
+#define __L2SH_PROTO_H
+
+#include "l2sh.h"
+#include <stddef.h>
+#include <string.h>
+
+#ifndef __packed
+#define __packed __attribute__((packed))
+#endif
+
+#define L2SH_ETHERTYPE 0x88B5
+#define L2SH_CLIENT_SIGNATURE 0xAABBCCDDu
+#define L2SH_SERVER_SIGNATURE 0xDDCCBBAAu
+#define L2SH_HELLO_VERSION 0x01
+#define L2SH_HELLO_T_SPAWN 0x01
+#define L2SH_HELLO_T_SHELL 0x02
+#define L2SH_HELLO_T_NONCE 0x03
+#define L2SH_HELLO_T_IDLE_TIMEOUT 0x04
+#define L2SH_HELLO_T_HEARTBEAT 0x05
+#define L2SH_MAC_LEN 6
+#define L2SH_NONCE_LEN 16
+#define L2SH_MAX_PAYLOAD 1024
+#define L2SH_MAX_DATA (L2SH_MAX_PAYLOAD - L2SH_NONCE_LEN)
+// prng = pseudo-random number generator
+// prng = псевдослучайный генератор чисел
+#define L2SH_PRNG32_MULT 1664525u
+#define L2SH_PRNG32_ADD 1013904223u
+
+struct l2sh_eth_hdr {
+  u8 et_dest[L2SH_MAC_LEN];
+  u8 et_src[L2SH_MAC_LEN];
+  be16 et_protlen;
+} __packed;
+
+struct l2sh_frame_hdr {
+  struct l2sh_eth_hdr eth;
+  be32 signature;
+  be32 payload_size;
+  be32 crc;
+} __packed;
+
+struct l2sh_frame {
+  struct l2sh_frame_hdr hdr;
+  u8 payload[L2SH_MAX_PAYLOAD];
+} __packed;
+
+struct l2sh_hello_view {
+  const u8 *cmd;
+  size_t cmd_len;
+  u64 nonce;
+  s32 shell_started;
+  s32 have_nonce;
+  s32 idle_timeout_seconds;
+  s32 have_idle_timeout;
+  s32 have_heartbeat;
+};
+
+static const u8 l2sh_shared_key[4] = { 0x4a, 0x17, 0x59, 0xc3 };
+
+// lcg constants for the per-byte keystream state update
+// коэффициенты lcg для обновления состояния побайтного keystream
+
+static inline u16 l2sh_get_be16(const u8 *buf)
+{
+  return ((u16)buf[0] << 8) | (u16)buf[1];
+}
+
+static inline u32 l2sh_get_be32(const u8 *buf)
+{
+  return ((u32)buf[0] << 24) | ((u32)buf[1] << 16) | ((u32)buf[2] << 8) | (u32)buf[3];
+}
+
+static inline u64 l2sh_get_be64(const u8 *buf)
+{
+  return ((u64)buf[0] << 56) | ((u64)buf[1] << 48) | ((u64)buf[2] << 40) | ((u64)buf[3] << 32) |
+         ((u64)buf[4] << 24) | ((u64)buf[5] << 16) | ((u64)buf[6] << 8) | (u64)buf[7];
+}
+
+static inline void l2sh_put_be16(u8 *buf, u16 val)
+{
+  buf[0] = (u8)(val >> 8);
+  buf[1] = (u8)val;
+}
+
+static inline void l2sh_put_be32(u8 *buf, u32 val)
+{
+  buf[0] = (u8)(val >> 24);
+  buf[1] = (u8)(val >> 16);
+  buf[2] = (u8)(val >> 8);
+  buf[3] = (u8)val;
+}
+
+static inline void l2sh_put_be64(u8 *buf, u64 val)
+{
+  buf[0] = (u8)(val >> 56);
+  buf[1] = (u8)(val >> 48);
+  buf[2] = (u8)(val >> 40);
+  buf[3] = (u8)(val >> 32);
+  buf[4] = (u8)(val >> 24);
+  buf[5] = (u8)(val >> 16);
+  buf[6] = (u8)(val >> 8);
+  buf[7] = (u8)val;
+}
+
+static inline u32 l2sh_csum32(const u8 *buf, size_t len)
+{
+  u32 sum;
+  size_t i;
+
+  if (!buf)
+    return 0;
+
+  sum = 0;
+  for (i = 0; i < len; i++)
+    sum += buf[i];
+
+  return sum;
+}
+
+static inline void l2sh_enc_dec(const u8 *input, u8 *output, const u8 *key, size_t len)
+{
+  u32 s;
+  size_t i;
+  u8 ks;
+
+  if (!input || !output || !key || !len)
+    return;
+
+  s = 0;
+  // pack the 4-byte key and payload length into one 32-bit prng state
+  // собираем 4 байта ключа и длину payload в одно 32-битное начальное состояние prng
+  s ^= (u32)key[0];
+  s ^= (u32)key[1] << 8;
+  s ^= (u32)key[2] << 16;
+  s ^= (u32)key[3] << 24;
+  s ^= (u32)len;
+
+  for (i = 0; i < len; i++) {
+    // one lcg step moves the 32-bit state to the next keystream position
+    // один шаг lcg переводит 32-битное состояние к следующему байту keystream
+    s = s * L2SH_PRNG32_MULT + L2SH_PRNG32_ADD;
+    // fold all 4 state bytes into one keystream byte
+    // xor между s, s >> 8, s >> 16 и s >> 24 схлопывает все 4 байта состояния в один keystream-байт
+    ks = (u8)(s ^ (s >> 8) ^ (s >> 16) ^ (s >> 24));
+    ks ^= (u8)i;
+    // stir the repeating key back into each output byte
+    // индекс i и циклический key[i & 3] не дают соседним байтам идти под одним и тем же xor-маском
+    ks = (u8)(ks + key[i & 3]);
+    output[i] = input[i] ^ ks;
+  }
+}
+
+static inline s32 l2sh_write_tlv(u8 *buf, size_t buf_len, size_t *off, u8 type, const void *data, u16 data_len)
+{
+  size_t need;
+
+  if (!buf || !off)
+    return -1;
+
+  need = (size_t)data_len + 3U;
+  if (*off > buf_len || buf_len - *off < need)
+    return -1;
+
+  buf[*off] = type;
+  l2sh_put_be16(buf + *off + 1, data_len);
+  if (data_len && data)
+    memcpy(buf + *off + 3, data, data_len);
+  *off += need;
+
+  return 0;
+}
+
+static inline s32 l2sh_build_hello(u8 *buf, size_t buf_len, const char *cmd, u64 nonce, s32 idle_timeout)
+{
+  u8 nonce_buf[sizeof(u64)];
+  u8 timeout_buf[sizeof(u32)];
+  const char *shell_cmd;
+  size_t cmd_len;
+  size_t off;
+
+  if (!buf || !buf_len)
+    return -1;
+
+  shell_cmd = cmd ? cmd : "";
+  cmd_len = strlen(shell_cmd);
+  if (cmd_len > 0xffffu)
+    return -1;
+
+  off = 0;
+  buf[off++] = L2SH_HELLO_VERSION;
+  if (l2sh_write_tlv(buf, buf_len, &off, L2SH_HELLO_T_SHELL, shell_cmd, (u16)cmd_len) < 0)
+    return -1;
+
+  l2sh_put_be64(nonce_buf, nonce);
+  if (l2sh_write_tlv(buf, buf_len, &off, L2SH_HELLO_T_NONCE, nonce_buf, sizeof(nonce_buf)) < 0)
+    return -1;
+
+  l2sh_put_be32(timeout_buf, idle_timeout > 0 ? (u32)idle_timeout : 0);
+  if (l2sh_write_tlv(buf, buf_len, &off, L2SH_HELLO_T_IDLE_TIMEOUT, timeout_buf, sizeof(timeout_buf)) < 0)
+    return -1;
+
+  return (s32)off;
+}
+
+static inline s32 l2sh_build_heartbeat(u8 *buf, size_t buf_len)
+{
+  size_t off;
+
+  if (!buf || !buf_len)
+    return -1;
+
+  off = 0;
+  buf[off++] = L2SH_HELLO_VERSION;
+  if (l2sh_write_tlv(buf, buf_len, &off, L2SH_HELLO_T_HEARTBEAT, NULL, 0) < 0)
+    return -1;
+
+  return (s32)off;
+}
+
+static inline s32 l2sh_hello_parse(const u8 *buf, size_t len, struct l2sh_hello_view *view)
+{
+  size_t off;
+  u16 tlv_len;
+  u8 type;
+
+  if (!buf || !len || !view)
+    return -1;
+
+  memset(view, 0, sizeof(*view));
+  if (buf[0] != L2SH_HELLO_VERSION)
+    return -1;
+
+  off = 1;
+  while (off + 3 <= len) {
+    type = buf[off++];
+    // tlv length is stored as two big-endian bytes
+    // длина tlv лежит в двух big-endian байтах: старший байт сначала, младший следом
+    tlv_len = l2sh_get_be16(buf + off);
+    off += sizeof(tlv_len);
+    if (off + tlv_len > len)
+      return -1;
+
+    switch (type) {
+    case L2SH_HELLO_T_SHELL:
+      view->cmd = buf + off;
+      view->cmd_len = tlv_len;
+      view->shell_started = 1;
+      break;
+    case L2SH_HELLO_T_NONCE:
+      if (tlv_len != sizeof(u64))
+        return -1;
+      // rebuild the 64-bit nonce from network-order bytes
+      // собираем u64 nonce через общий helper для сетевого big-endian
+      view->nonce = l2sh_get_be64(buf + off);
+      view->have_nonce = 1;
+      break;
+    case L2SH_HELLO_T_IDLE_TIMEOUT:
+      if (tlv_len != sizeof(u32))
+        return -1;
+      // rebuild the 32-bit timeout from network-order bytes
+      // собираем u32 timeout через общий helper для сетевого big-endian
+      view->idle_timeout_seconds = (s32)l2sh_get_be32(buf + off);
+      view->have_idle_timeout = 1;
+      break;
+    case L2SH_HELLO_T_HEARTBEAT:
+      view->have_heartbeat = 1;
+      break;
+    case L2SH_HELLO_T_SPAWN:
+    default:
+      break;
+    }
+
+    off += tlv_len;
+  }
+
+  if (off != len)
+    return -1;
+
+  return 0;
+}
+
+static inline size_t l2sh_frame_wire_size(size_t payload_len)
+{
+  if (payload_len > L2SH_MAX_DATA)
+    return 0;
+
+  return sizeof(struct l2sh_frame_hdr) + L2SH_NONCE_LEN + payload_len;
+}
+
+static inline s32 l2sh_frame_build(struct l2sh_frame *frame, const u8 *src, const u8 *dst, u32 signature, const void *payload, size_t payload_len, const u8 *nonce)
+{
+  size_t frame_len;
+  u8 *nonce_ptr;
+  u8 *data_ptr;
+  u32 crc;
+  size_t i;
+
+  if (!frame || !src || !dst || !nonce)
+    return -1;
+  if (payload_len > L2SH_MAX_DATA)
+    return -1;
+  if (payload_len && !payload)
+    return -1;
+
+  memset(frame, 0, sizeof(*frame));
+  memcpy(frame->hdr.eth.et_src, src, L2SH_MAC_LEN);
+  memcpy(frame->hdr.eth.et_dest, dst, L2SH_MAC_LEN);
+  frame->hdr.eth.et_protlen = cpu_to_be16(L2SH_ETHERTYPE);
+  frame->hdr.signature = cpu_to_be32(signature);
+  frame->hdr.payload_size = cpu_to_be32((u32)(L2SH_NONCE_LEN + payload_len));
+
+  nonce_ptr = frame->payload;
+  data_ptr = frame->payload + L2SH_NONCE_LEN;
+  memcpy(nonce_ptr, nonce, L2SH_NONCE_LEN);
+  if (payload_len)
+    memcpy(data_ptr, payload, payload_len);
+
+  // first xor the payload with the per-frame nonce
+  // сначала xor'им payload с nonce кадра, чтобы одинаковые данные в разных кадрах выглядели по-разному
+  for (i = 0; i < payload_len; i++)
+    data_ptr[i] ^= nonce_ptr[i & (L2SH_NONCE_LEN - 1)];
+  // then run the shared stream layer used by both sides
+  // потом прогоняем общий потоковый xor-слой, одинаковый у клиента и сервера
+  l2sh_enc_dec(data_ptr, data_ptr, l2sh_shared_key, payload_len);
+
+  frame_len = l2sh_frame_wire_size(payload_len);
+  // crc covers the frame before the crc-derived mask is applied
+  // crc считается по кадру до финальной маски, иначе принимающая сторона не смогла бы проверить целостность
+  crc = l2sh_csum32((const u8 *)frame, frame_len);
+  frame->hdr.crc = cpu_to_be32(crc);
+  // final mask ties the payload bytes to this exact frame crc
+  // финальная маска привязывает payload именно к этому crc, чтобы кадры нельзя было просто переставлять как есть
+  l2sh_enc_dec(data_ptr, data_ptr, (const u8 *)&frame->hdr.crc, payload_len);
+
+  return (int)frame_len;
+}
+
+static inline s32 l2sh_frame_parse(struct l2sh_frame *frame, size_t frame_len, u32 signature, u8 **payload, size_t *payload_len)
+{
+  size_t enc_len;
+  size_t data_len;
+  size_t expect_len;
+  u32 recv_crc;
+  u32 calc_crc;
+  u32 saved_crc;
+  u8 nonce[L2SH_NONCE_LEN];
+  u8 *nonce_ptr;
+  u8 *data_ptr;
+  size_t i;
+
+  if (!frame || frame_len < sizeof(frame->hdr))
+    return -1;
+  if (be16_to_cpu(frame->hdr.eth.et_protlen) != L2SH_ETHERTYPE)
+    return -1;
+  if (be32_to_cpu(frame->hdr.signature) != signature)
+    return -1;
+
+  enc_len = be32_to_cpu(frame->hdr.payload_size);
+  if (enc_len < L2SH_NONCE_LEN || enc_len > L2SH_MAX_PAYLOAD)
+    return -1;
+
+  expect_len = sizeof(frame->hdr) + enc_len;
+  if (frame_len < expect_len)
+    return -1;
+
+  data_len = enc_len - L2SH_NONCE_LEN;
+  nonce_ptr = frame->payload;
+  data_ptr = frame->payload + L2SH_NONCE_LEN;
+  recv_crc = be32_to_cpu(frame->hdr.crc);
+
+  // remove the crc-derived mask first so crc can be checked
+  // сначала снимаем crc-маску, иначе пересчитанный crc никогда не совпадет
+  l2sh_enc_dec(data_ptr, data_ptr, (const u8 *)&frame->hdr.crc, data_len);
+
+  saved_crc = frame->hdr.crc;
+  frame->hdr.crc = 0;
+  // crc is computed with the crc field zeroed
+  // поле crc зануляется на время расчета, чтобы сумма не зависела от самой себя
+  calc_crc = l2sh_csum32((const u8 *)frame, expect_len);
+  frame->hdr.crc = saved_crc;
+  if (recv_crc != calc_crc)
+    return -1;
+
+  memcpy(nonce, nonce_ptr, sizeof(nonce));
+  // then remove the shared stream layer
+  // после проверки crc снимаем общий потоковый xor-слой
+  l2sh_enc_dec(data_ptr, data_ptr, l2sh_shared_key, data_len);
+  // finally xor back with the saved nonce to get plain bytes
+  // в конце xor'им обратно сохраненным nonce и получаем исходный payload
+  for (i = 0; i < data_len; i++)
+    frame->payload[i] = data_ptr[i] ^ nonce[i & (L2SH_NONCE_LEN - 1)];
+
+  if (payload)
+    *payload = frame->payload;
+  if (payload_len)
+    *payload_len = data_len;
+
+  return 0;
+}
+
+#endif
