From 58d2fae240e28b1cc0ab365c120833fa10c8329e Mon Sep 17 00:00:00 2001
From: Ruslan Isaev <legale.legale@gmail.com>
Date: Mon, 4 May 2026 23:47:47 +0300
Subject: [PATCH] net: fix l2sh RX handling

---
 include/l2sh.h |   7 ++
 net/l2sh.c     | 131 ++++++++++------------
 net/net.c      |  14 ++-
 3 files changed, 76 insertions(+), 76 deletions(-)

diff --git a/include/l2sh.h b/include/l2sh.h
index c3e730b22..00cbe7012 100644
--- a/include/l2sh.h
+++ b/include/l2sh.h
@@ -48,6 +48,7 @@ typedef u8 be8;
 #if defined(CONFIG_L2SH) && !defined(CONFIG_XPL_BUILD)
 s32 l2sh_init(void);
 void l2sh_poll(void);
+void l2sh_rx(const u8 *packet, u32 len);
 s32 l2sh_tstc(void);
 s32 l2sh_getc(void);
 void l2sh_putc(const char c);
@@ -62,6 +63,12 @@ static inline void l2sh_poll(void)
 {
 }
 
+static inline void l2sh_rx(const u8 *packet, u32 len)
+{
+  (void)packet;
+  (void)len;
+}
+
 static inline s32 l2sh_tstc(void)
 {
   return 0;
diff --git a/net/l2sh.c b/net/l2sh.c
index 20b26dddb..aa41e5bda 100644
--- a/net/l2sh.c
+++ b/net/l2sh.c
@@ -18,7 +18,6 @@
 #define L2SH_HELLO_TIMEOUT_MAX 600
 #define L2SH_ETH_RETRY_MIN_MS 5000UL
 #define L2SH_ETH_RETRY_MAX_MS 30000UL
-#define L2SH_RX_BUDGET 8
 #define L2SH_TX_BUDGET 8
 
 struct l2sh_ring {
@@ -52,7 +51,6 @@ struct l2sh_ctx {
   u8 peer_mac[ARP_HLEN];
   struct l2sh_ring rx_ring;
   struct l2sh_ring tx_ring;
-  l2s_frame_t rx_frame;
   l2s_frame_t tx_frame;
   u8 rx_buf[CONFIG_L2SH_RX_SIZE];
   u8 tx_buf[CONFIG_L2SH_TX_SIZE];
@@ -61,6 +59,7 @@ struct l2sh_ctx {
 };
 
 static struct l2sh_ctx l2sh;
+extern int net_busy_flag;
 static void l2sh_reset_session(void);
 
 static s32 l2sh_dbg_enabled(void) {
@@ -512,6 +511,59 @@ static void l2sh_tx_drain(void) {
   }
 }
 
+void l2sh_rx(const u8 *packet, u32 len) {
+  l2s_frame_t *frame;
+  const u8 *payload;
+  const u8 *our_mac;
+  size_t payload_len;
+  u32 sig;
+  be16 etype;
+  s32 parse_ret;
+  char src_mac[18];
+  char dst_mac[18];
+
+  l2sh_init();
+
+  if (!l2sh_runtime_enabled())
+    return;
+
+  if (!packet || len < sizeof(l2s_frame_header_t))
+    return;
+
+  our_mac = eth_get_ethaddr();
+  if (!our_mac)
+    return;
+
+  frame = (l2s_frame_t *)packet;
+  etype = frame->header.eth_hdr.ether_type;
+  if (be16_to_cpu(etype) != L2SH_ETHERTYPE)
+    return;
+
+  if (!l2sh_accept_dst_mac(frame->header.eth_hdr.ether_dhost, our_mac))
+    return;
+
+  sig = be32_to_cpu(frame->header.signature);
+  l2sh_dbg("rx raw len=%u src=%s dst=%s sig=%08x state=%s",
+           len,
+           l2sh_fmt_mac(frame->header.eth_hdr.ether_shost,
+                        src_mac, sizeof(src_mac)),
+           l2sh_fmt_mac(frame->header.eth_hdr.ether_dhost,
+                        dst_mac, sizeof(dst_mac)),
+           sig, l2sh_state_name(l2sh.state));
+
+  parse_ret = l2s_parse_frame(frame, len, L2SH_CLIENT_SIGNATURE, &payload_len);
+  if (parse_ret) {
+    l2sh_dbg("parse failed ret=%d sig=%08x len=%u", parse_ret, sig, len);
+    return;
+  }
+
+  if (l2sh_drop_dup(frame, len))
+    return;
+
+  payload = frame->payload;
+  l2sh_handle_payload(frame->header.eth_hdr.ether_shost, payload, payload_len);
+}
+
 s32 l2sh_init(void) {
   if (l2sh.inited) return 0;
 
@@ -524,21 +576,7 @@ s32 l2sh_init(void) {
 }
 
 void l2sh_poll(void) {
-  struct udevice *dev;
-  const u8 *our_mac;
-  uchar *packet;
-  struct eth_ops *ops;
-  l2s_frame_t *frame;
-  const u8 *payload;
-  size_t payload_len;
-  u32 sig;
-  be16 etype;
-  s32 parse_ret;
   s32 ret;
-  s32 budget;
-  char src_mac[18];
-  char dst_mac[18];
-  static s32 announced;
 
   l2sh_init();
 
@@ -555,63 +593,16 @@ void l2sh_poll(void) {
     goto out;
   }
 
-  dev = eth_get_dev();
-  if (!dev)
-    goto out;
-
-  our_mac = eth_get_ethaddr();
-  if (!our_mac)
-    goto out;
-
-  if (l2sh_dbg_enabled() && !announced) {
-    announced = 1;
-    l2sh_dbg("enabled dev=%s mac=%s", dev->name, l2sh_fmt_mac(our_mac, dst_mac, sizeof(dst_mac)));
-  }
-
-  if (l2sh_ensure_eth())
-    goto out;
-
-  l2sh_check_timeout();
-
-  ops = eth_get_ops(dev);
-  budget = L2SH_RX_BUDGET;
-  while (budget--) {
-    packet = NULL;
-    // first pass checks device state, later passes just drain queued frames
-    // первый вызов дает драйверу проверить состояние устройства, дальше просто вычитываем хвост очереди
-    ret = ops->recv(dev, budget == L2SH_RX_BUDGET - 1 ? ETH_RECV_CHECK_DEVICE : 0, &packet);
-    if (ret > 0 && packet && (size_t)ret >= sizeof(l2s_frame_header_t)) {
-      frame = (l2s_frame_t *)packet;
-      etype = frame->header.eth_hdr.ether_type;
-      sig = be32_to_cpu(frame->header.signature);
-      if (be16_to_cpu(etype) == L2SH_ETHERTYPE &&
-          l2sh_accept_dst_mac(frame->header.eth_hdr.ether_dhost, our_mac)) {
-        l2sh_dbg("rx raw len=%d src=%s dst=%s sig=%08x state=%s",
-                 ret,
-                 l2sh_fmt_mac(frame->header.eth_hdr.ether_shost, src_mac, sizeof(src_mac)),
-                 l2sh_fmt_mac(frame->header.eth_hdr.ether_dhost, dst_mac, sizeof(dst_mac)), sig, l2sh_state_name(l2sh.state));
-      }
-
-      parse_ret = l2s_parse_frame(frame, ret, L2SH_CLIENT_SIGNATURE, &payload_len);
-      if (!l2sh_drop_dup(frame, ret) &&
-          l2sh_accept_dst_mac(frame->header.eth_hdr.ether_dhost, our_mac) &&
-          parse_ret == L2S_FRAME_OK) {
-        payload = frame->payload;
-        l2sh_handle_payload(frame->header.eth_hdr.ether_shost, payload, payload_len);
-      } else if (be16_to_cpu(etype) == L2SH_ETHERTYPE &&
-                 l2sh_accept_dst_mac(frame->header.eth_hdr.ether_dhost, our_mac) &&
-                 parse_ret) {
-        l2sh_dbg("parse failed ret=%d sig=%08x len=%d", parse_ret, sig, ret);
-      }
+  if (!net_busy_flag) {
+    ret = l2sh_ensure_eth();
+    if (!ret) {
+      ret = net_init();
+      if (!ret)
+        (void)eth_rx();
     }
-
-    if (ret >= 0 && ops->free_pkt)
-      ops->free_pkt(dev, packet, ret);
-
-    if (ret <= 0)
-      break;
   }
 
+  l2sh_check_timeout();
   l2sh_tx_drain();
 
 out:
diff --git a/net/net.c b/net/net.c
index f579f6ac5..f0256540b 100644
--- a/net/net.c
+++ b/net/net.c
@@ -86,6 +86,8 @@
 #include <env_internal.h>
 #include <errno.h>
 #include <image.h>
+#include <l2sh.h>
+#include <l2sh_proto.h>
 #include <led.h>
 #include <log.h>
 #if defined(CONFIG_LED_STATUS)
@@ -471,9 +473,7 @@ int net_loop(enum proto_t protocol)
 	}
 
 restart:
-#ifdef CONFIG_USB_KEYBOARD
 	net_busy_flag = 0;
-#endif
 	net_set_state(NETLOOP_CONTINUE);
 
 	/*
@@ -628,9 +628,7 @@ restart:
 		status_led_set(CONFIG_LED_STATUS_RED, CONFIG_LED_STATUS_ON);
 #endif /* CONFIG_SYS_FAULT_ECHO_LINK_DOWN, ... */
 #endif /* CONFIG_MII, ... */
-#ifdef CONFIG_USB_KEYBOARD
 	net_busy_flag = 1;
-#endif
 
 	/*
 	 *	Main packet reception loop.  Loop receiving packets until
@@ -757,9 +755,7 @@ restart:
 	}
 
 done:
-#ifdef CONFIG_USB_KEYBOARD
 	net_busy_flag = 0;
-#endif
 #ifdef CONFIG_CMD_TFTPPUT
 	/* Clear out the handlers */
 	net_set_udp_handler(NULL);
@@ -1214,6 +1210,7 @@ void net_process_received_packet(uchar *in_packet, int len)
 	struct in_addr dst_ip;
 	struct in_addr src_ip;
 	int eth_proto;
+	int frame_len = len;
 #if defined(CONFIG_CMD_CDP)
 	int iscdp;
 #endif
@@ -1314,6 +1311,11 @@ void net_process_received_packet(uchar *in_packet, int len)
 			return;
 	}
 
+	if (eth_proto == L2SH_ETHERTYPE) {
+		l2sh_rx(in_packet, frame_len);
+		return;
+	}
+
 	switch (eth_proto) {
 	case PROT_ARP:
 		arp_receive(et, ip, len);
-- 
2.39.5

