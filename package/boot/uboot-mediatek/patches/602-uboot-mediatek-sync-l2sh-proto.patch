+static inline void hello_generate_nonce(u8 *nonce, size_t len) {
+  static u64 hello_nonce_counter;
+  u64 state;
+  size_t i = 0;
+
+  if (!nonce || len == 0)
+    return;
+
+  state = hello_nonce_seed() ^ (++hello_nonce_counter);
+  while (i < len) {
+    size_t chunk = len - i;
+    u64 mixed;
