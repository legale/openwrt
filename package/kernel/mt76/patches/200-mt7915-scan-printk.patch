@@ -1021,6 +1021,10 @@ int __mt76_set_channel(struct mt76_phy *
 		       bool offchannel)
 {
 	struct mt76_dev *dev = phy->dev;
+	bool prev_offchannel = phy->offchannel;
+	u32 prev_main_freq = phy->main_chandef.chan ?
+			     phy->main_chandef.chan->center_freq : 0;
