 #include "mt7915.h"
 #include "mcu.h"
 
+static void mt7915_sw_scan_start(struct ieee80211_hw *hw,
+				 struct ieee80211_vif *vif,
+				 const u8 *mac)
+{
+	struct mt7915_dev *dev = mt7915_hw_dev(hw);
+	struct mt7915_phy *phy = mt7915_hw_phy(hw);
+	struct cfg80211_chan_def *chandef = &phy->mt76->chandef;
+	u64 now_ns = ktime_get_boottime_ns();
+	u32 freq = chandef->chan ? chandef->chan->center_freq : 0;
+
+	phy->dbg_scan_start_ns = now_ns;
+
+	printk(KERN_INFO "mt76: event=scan_sw_start ts_ms=%llu chip=0x%04x band=%u freq=%u\n",
+	       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+	       mt76_chip(&dev->mt76), phy->mt76->band_idx, freq);
+
+	/* Keep mt76 state tracking */
+	mt76_sw_scan(hw, vif, mac);
+}
+
+static void mt7915_sw_scan_complete(struct ieee80211_hw *hw,
+				    struct ieee80211_vif *vif)
+{
+	struct mt7915_dev *dev = mt7915_hw_dev(hw);
+	struct mt7915_phy *phy = mt7915_hw_phy(hw);
+	struct cfg80211_chan_def *chandef = &phy->mt76->chandef;
+	u64 now_ns = ktime_get_boottime_ns();
+	u64 dur_ms = 0;
+	u32 freq = chandef->chan ? chandef->chan->center_freq : 0;
+
+	if (phy->dbg_scan_start_ns)
+		dur_ms = div_u64(now_ns - phy->dbg_scan_start_ns,
+				 NSEC_PER_MSEC);
+
+	printk(KERN_INFO "mt76: event=scan_sw_done ts_ms=%llu chip=0x%04x band=%u freq=%u dur_ms=%llu\n",
+	       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+	       mt76_chip(&dev->mt76), phy->mt76->band_idx, freq,
+	       (unsigned long long)dur_ms);
+
+	phy->dbg_scan_start_ns = 0;
+
+	/* Keep mt76 state tracking */
+	mt76_sw_scan_complete(hw, vif);
+}
+
