 	int timeout = HZ / 5;
 	int ret;
 
@@ -1046,6 +1050,40 @@ int __mt76_set_channel(struct mt76_phy *
 
 	ret = dev->drv->set_channel(phy);
 
+	if (!ret) {
+		bool dbg_scan = test_bit(MT76_SCANNING, &phy->state) ||
+				test_bit(MT76_HW_SCANNING, &phy->state);
+		bool dbg_roc = !!phy->roc_vif;
+
+		if ((dbg_scan || dbg_roc) && !prev_offchannel && offchannel) {
+			u64 now_ns = ktime_get_boottime_ns();
+
+			phy->dbg_offchan_enter_ns = now_ns;
+			phy->dbg_offchan_enter_freq = new_freq;
+			phy->dbg_offchan_enter_main_freq = prev_main_freq;
+			printk(KERN_INFO
+			       "mt76: event=offchan_enter ts_ms=%llu chip=0x%04x band=%u freq=%u main_freq=%u scan=%d roc=%d\n",
+			       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+			       mt76_chip(dev), phy->band_idx, new_freq, prev_main_freq,
+			       dbg_scan, dbg_roc);
+		} else if (prev_offchannel && !offchannel && phy->dbg_offchan_enter_ns) {
+			u64 now_ns = ktime_get_boottime_ns();
+			u64 dur_ms = div_u64(now_ns - phy->dbg_offchan_enter_ns,
+					     NSEC_PER_MSEC);
+
+			printk(KERN_INFO
+			       "mt76: event=offchan_exit ts_ms=%llu chip=0x%04x band=%u freq=%u main_freq=%u offchan_freq=%u offchan_dur_ms=%llu scan=%d roc=%d\n",
+			       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+			       mt76_chip(dev),
+			       phy->band_idx, new_freq,
+			       phy->main_chandef.chan ? phy->main_chandef.chan->center_freq : 0,
+			       phy->dbg_offchan_enter_freq,
+			       (unsigned long long)dur_ms,
+			       dbg_scan, dbg_roc);
+			phy->dbg_offchan_enter_ns = 0;
+		}
+	}
+
 	clear_bit(MT76_RESET, &phy->state);
 	mt76_worker_enable(&dev->tx_worker);
 	mt76_worker_schedule(&dev->tx_worker);
@@ -1923,16 +1961,48 @@ void mt76_sw_scan(struct ieee80211_hw *h
 		  const u8 *mac)
 {
 	struct mt76_phy *phy = hw->priv;
+	struct mt76_dev *dev = phy->dev;
+	u64 now_ns;
+	u32 freq = 0;
 
 	set_bit(MT76_SCANNING, &phy->state);
+
+	now_ns = ktime_get_boottime_ns();
+	if (phy->chandef.chan)
+		freq = phy->chandef.chan->center_freq;
+	phy->dbg_scan_start_ns = now_ns;
+	phy->dbg_scan_start_freq = freq;
+
+	printk(KERN_INFO
+	       "mt76: event=scan_sw_start ts_ms=%llu chip=0x%04x band=%u freq=%u\n",
+	       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+	       mt76_chip(dev), phy->band_idx, freq);
 }
 EXPORT_SYMBOL_GPL(mt76_sw_scan);
 
 void mt76_sw_scan_complete(struct ieee80211_hw *hw, struct ieee80211_vif *vif)
 {
 	struct mt76_phy *phy = hw->priv;
+	struct mt76_dev *dev = phy->dev;
+	u64 now_ns, dur_ms = 0;
+	u32 freq = 0;
 
 	clear_bit(MT76_SCANNING, &phy->state);
+
+	now_ns = ktime_get_boottime_ns();
+	if (phy->chandef.chan)
+		freq = phy->chandef.chan->center_freq;
+	if (phy->dbg_scan_start_ns)
+		dur_ms = div_u64(now_ns - phy->dbg_scan_start_ns,
+				 NSEC_PER_MSEC);
+
+	printk(KERN_INFO
+	       "mt76: event=scan_sw_done ts_ms=%llu chip=0x%04x band=%u freq=%u dur_ms=%llu\n",
+	       (unsigned long long)div_u64(now_ns, NSEC_PER_MSEC),
+	       mt76_chip(dev), phy->band_idx, freq,
+	       (unsigned long long)dur_ms);
+
+	phy->dbg_scan_start_ns = 0;
 }
 EXPORT_SYMBOL_GPL(mt76_sw_scan_complete);
 
